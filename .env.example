# Anthropic - usado pelo Planejador (Claude Sonnet 4.6)
ANTHROPIC_API_KEY=sk-ant-...

# Infomaniak - usado pelo Motor Drota (Mistral Small)
INFOMANIAK_API_KEY=...
INFOMANIAK_BASE_URL=https://api.infomaniak.com/1/ai/...

# Opcional: sobrescreve modelo padrao por servico
PLANEJADOR_MODEL=claude-sonnet-4-6
MOTOR_DROTA_MODEL=mistral-small-latest
